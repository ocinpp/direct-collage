# ─────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────
node_modules/

# ─────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────
# TypeScript / bundler output dirs
dist/
build/
# Per-project tsconfig.node.json outDir (composite project build cache)
dist-node/
# TypeScript incremental build info
*.tsbuildinfo

# Vite
*.local
.vite/

# ─────────────────────────────────────────────────────────────
# Server — runtime data
# ─────────────────────────────────────────────────────────────
# Uploaded composite JPEGs (served statically; never commit user content)
server/uploads/
# SQLite database + WAL/SHM sidecars
server/prisma/*.db
server/prisma/*.db-journal
server/prisma/*.db-wal
server/prisma/*.db-shm

# ─────────────────────────────────────────────────────────────
# Environment & secrets
# ─────────────────────────────────────────────────────────────
# Real env files (contain JWT secret, LAN IP, etc.)
.env
.env.local
.env.*.local
# Per-workspace env
server/.env
submission/.env
admin/.env
wall/.env
# NOTE: *.env.example files ARE committed (template only, no secrets).

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# Test / coverage
# ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

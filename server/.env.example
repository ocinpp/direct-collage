# Server
# Port the Express API + static uploads are served on
PORT=4000

# Public base URL where the server is reachable (used to build composite URLs).
# For local dev with the default ports, leave as below.
# On a real network/phone, set to http://<your-lan-ip>:4000
PUBLIC_BASE_URL=http://localhost:4000

# JWT signing secret for admin sessions. CHANGE THIS in any non-demo deploy.
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d

# Admin seed credentials (used by prisma/seed.ts only)
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=changeme

# Composite upload constraints
MAX_UPLOAD_BYTES=3145728
